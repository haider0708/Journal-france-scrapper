# ===========================================================================
# Legifrance JO Monitor -- configuration
# Copy to .env for local development. On Render, set these in the dashboard.
# ===========================================================================

# --- Legifrance / PISTE API ------------------------------------------------
# Create a free app at https://piste.gouv.fr, subscribe it to "Légifrance",
# then copy the OAuth Client ID / Secret.
PISTE_CLIENT_ID=your_client_id_here
PISTE_CLIENT_SECRET=your_client_secret_here
PISTE_SANDBOX=false

# --- What to search for ----------------------------------------------------
# ";"-separated names. Matches are accent/case-insensitive and order-agnostic;
# a single-token (first-name-only or surname-only) hit is flagged as PARTIAL.
SEARCH_NAMES=Lobna Marsaoui

# How many recent JO editions to look back over (only new ones are processed).
LOOKBACK_EDITIONS=15
# Politeness delay between API calls (seconds).
REQUEST_DELAY_S=0.3

# --- Email alerts (Resend -- https://resend.com) ---------------------------
EMAIL_ENABLED=true
RESEND_API_KEY=your_resend_api_key_here
EMAIL_FROM=onboarding@resend.dev
EMAIL_TO=you@example.com

# --- State persistence -----------------------------------------------------
# Leave DATABASE_URL EMPTY locally -> uses state.json / matches.jsonl files.
# On Render (ephemeral filesystem) you MUST set a Postgres DSN, e.g. from Neon:
#   postgresql://user:pass@ep-xxx.eu-central-1.aws.neon.tech/db?sslmode=require
DATABASE_URL=

# --- Web service security --------------------------------------------------
# Secret required to call POST /scan. Generate a long random string.
CRON_SECRET=change_me_to_a_long_random_string

# --- Misc ------------------------------------------------------------------
LOG_LEVEL=INFO
