# ===========================================================================
# Legifrance JO Monitor -- configuration
#
# Local dev (no Docker):  copy to .env, leave DATABASE_URL empty -> uses files.
# Docker / VPS:           copy to .env on the server; docker-compose reads it.
# ===========================================================================

# --- Legifrance / PISTE API ------------------------------------------------
# Create a free app at https://piste.gouv.fr, subscribe it to "Légifrance",
# then copy the OAuth Client ID / Secret.
PISTE_CLIENT_ID=your_client_id_here
PISTE_CLIENT_SECRET=your_client_secret_here
PISTE_SANDBOX=false

# --- What to search for ----------------------------------------------------
# ";"-separated names. Matches are accent/case-insensitive and order-agnostic;
# a single-token (first-name-only or surname-only) hit is flagged as PARTIAL.
SEARCH_NAMES=Lobna Marsaoui
LOOKBACK_EDITIONS=15
REQUEST_DELAY_S=0.3

# --- Email alerts (Resend -- https://resend.com) ---------------------------
EMAIL_ENABLED=true
RESEND_API_KEY=your_resend_api_key_here
EMAIL_FROM=onboarding@resend.dev
EMAIL_TO=you@example.com

# --- Internal scheduler (Docker / VPS: app schedules its own scans) --------
SCHEDULER_ENABLED=true
SCAN_INTERVAL_MINUTES=720
SCAN_ON_STARTUP=true

# --- Manual /scan trigger secret -------------------------------------------
# Optional when using the internal scheduler. Required to call POST /scan.
CRON_SECRET=change_me_to_a_long_random_string

# --- PostgreSQL (used by docker-compose to create the DB container) --------
# docker-compose builds DATABASE_URL from these; you do NOT set DATABASE_URL.
POSTGRES_USER=legifrance
POSTGRES_PASSWORD=change_me_strong_db_password
POSTGRES_DB=legifrance

# --- DATABASE_URL ----------------------------------------------------------
# Local dev WITHOUT Docker: leave empty -> state stored in state.json files.
# Docker-compose sets this automatically (ignore it here).
# Managed Postgres (e.g. Neon) without compose: put the DSN here.
DATABASE_URL=

# --- Host port mapping (docker-compose) ------------------------------------
APP_PORT=8000

LOG_LEVEL=INFO
